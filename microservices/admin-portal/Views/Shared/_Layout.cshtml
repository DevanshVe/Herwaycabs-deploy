<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HerWayCabs Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="hwc-navbar">
            <div class="container d-flex align-items-center justify-content-between">
                <a class="hwc-brand" asp-controller="Admin" asp-action="Index">
                    <span class="hwc-logo">H</span> HerWayCabs <span class="hwc-brand-sub">Admin</span>
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="hwc-nav-right">
                        <span class="hwc-user">@User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="hwc-logout-form">
                            <button type="submit" class="hwc-logout-btn">Logout</button>
                        </form>
                    </div>
                }
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="hwc-footer text-center">
        <div class="container">&copy; 2026 HerWayCabs · Admin Console</div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
