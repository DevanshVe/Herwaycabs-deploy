@model List<admin_portal.Models.RideViewModel>
@{
    ViewData["Title"] = "Rides";

    string BadgeClass(string? status) => (status ?? "").ToUpper() switch
    {
        "PAID" => "hwc-badge-green",
        "COMPLETED" => "hwc-badge-green",
        "CANCELLED" => "hwc-badge-gray",
        "STARTED" => "hwc-badge-blue",
        "DRIVER_ASSIGNED" => "hwc-badge-blue",
        "REQUESTED" => "hwc-badge-amber",
        _ => "hwc-badge-gray",
    };
}

<div class="hwc-page-head">
    <h1>Rides</h1>
    <p>Every ride on HerWayCabs — @(Model?.Count ?? 0) total.</p>
</div>

@if (ViewBag.LoadError == true)
{
    <div class="hwc-flash hwc-flash-err">Couldn't load rides — the booking service may be waking up. Refresh in a moment.</div>
}
else if (Model == null || !Model.Any())
{
    <div class="hwc-empty">
        <div class="hwc-empty-icon" style="background:#fce7f3;color:#db2777;">&#128661;</div>
        <p>No rides yet.</p>
    </div>
}
else
{
    <div class="hwc-toolbar" id="ridesToolbar">
        <input type="search" class="hwc-search" data-search-input placeholder="Search by id, location or user…" aria-label="Search rides" />
        <select class="hwc-filter" data-filter="status" aria-label="Filter by status">
            <option value="">All statuses</option>
            <option value="REQUESTED">Requested</option>
            <option value="DRIVER_ASSIGNED">Driver assigned</option>
            <option value="STARTED">Started</option>
            <option value="COMPLETED">Completed</option>
            <option value="PAID">Paid</option>
            <option value="CANCELLED">Cancelled</option>
        </select>
        <span class="hwc-count"><strong data-count>@Model.Count</strong> shown</span>
    </div>

    <div class="hwc-table-wrap" data-tools data-toolbar="#ridesToolbar" data-page-size="10">
        <table class="hwc-table">
            <thead>
                <tr><th>Ride</th><th>Route</th><th>Rider / Driver</th><th>Cab</th><th>Fare</th><th>Rating</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var r in Model.OrderByDescending(x => x.Id))
                {
                    var status = (r.Status ?? "").ToUpper();
                    var cab = (r.CabType ?? "ECONOMY").ToUpper();
                    var cabClass = cab == "LUXURY" ? "hwc-badge-dark" : "hwc-badge-gray";
                    <tr data-status="@status" data-search="@($"#{r.Id} {r.PickupLocation} {r.DropLocation} rider {r.RiderId} driver {r.DriverId} {cab}")">
                        <td>
                            <div class="hwc-cell-name">#@r.Id</div>
                            <div class="hwc-cell-sub">@(r.RequestTime?.ToString("dd MMM yyyy, HH:mm") ?? "—")</div>
                        </td>
                        <td>
                            <div>@r.PickupLocation</div>
                            <div class="hwc-cell-sub">&#8594; @r.DropLocation</div>
                        </td>
                        <td>
                            <div>Rider #@(r.RiderId?.ToString() ?? "—")</div>
                            <div class="hwc-cell-sub">Driver @(r.DriverId.HasValue ? "#" + r.DriverId : "unassigned")</div>
                        </td>
                        <td><span class="hwc-badge @cabClass">@(cab == "LUXURY" ? "Luxury" : "Economy")</span></td>
                        <td><strong>&#8377;@Math.Round(r.Fare)</strong></td>
                        <td>
                            @if (r.DriverRating.HasValue)
                            {
                                <span title="@r.DriverFeedback" style="color:#f59e0b; white-space:nowrap;">@(new string('★', r.DriverRating.Value))<span style="color:#e5e7eb;">@(new string('☆', 5 - r.DriverRating.Value))</span></span>
                            }
                            else
                            {
                                <span class="hwc-cell-sub">&mdash;</span>
                            }
                        </td>
                        <td><span class="hwc-badge @BadgeClass(r.Status)">@(status.Replace("_", " "))</span></td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="hwc-no-match" data-empty style="display:none;">No rides match your search.</div>
    </div>
}
