@model List<admin_portal.Models.UserViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="hwc-page-head">
    <h1>Users</h1>
    <p>Everyone registered on HerWayCabs — @(Model?.Count ?? 0) total.</p>
</div>

@if (ViewBag.LoadError == true)
{
    <div class="hwc-flash hwc-flash-err">Couldn't load users — the auth service may be waking up. Refresh in a moment.</div>
}
else if (Model == null || !Model.Any())
{
    <div class="hwc-empty">
        <div class="hwc-empty-icon" style="background:#fce7f3;color:#db2777;">&#128100;</div>
        <p>No users yet.</p>
    </div>
}
else
{
    <div class="hwc-toolbar" id="usersToolbar">
        <input type="search" class="hwc-search" data-search-input placeholder="Search by name, email or phone…" aria-label="Search users" />
        <select class="hwc-filter" data-filter="role" aria-label="Filter by role">
            <option value="">All roles</option>
            <option value="RIDER">Riders</option>
            <option value="DRIVER">Drivers</option>
            <option value="ADMIN">Admins</option>
        </select>
        <span class="hwc-count"><strong data-count>@Model.Count</strong> shown</span>
    </div>

    <div class="hwc-table-wrap" data-tools data-toolbar="#usersToolbar" data-page-size="10">
        <table class="hwc-table">
            <thead>
                <tr><th>User</th><th>Contact</th><th>Role</th><th>Gender</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    var role = (u.Role ?? "RIDER").ToUpper();
                    var roleClass = role == "ADMIN" ? "hwc-badge-dark" : role == "DRIVER" ? "hwc-badge-blue" : "hwc-badge-pink";
                    <tr data-role="@role" data-search="@($"{u.Name} {u.Email} {u.PhoneNumber}")">
                        <td>
                            <div class="hwc-cell-user">
                                <div class="hwc-avatar-sm">@(string.IsNullOrEmpty(u.Name) ? "U" : u.Name.Substring(0, 1).ToUpper())</div>
                                <div>
                                    <div class="hwc-cell-name">@u.Name</div>
                                    <div class="hwc-cell-sub">#@u.Id</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div>@u.Email</div>
                            <div class="hwc-cell-sub">@u.PhoneNumber</div>
                        </td>
                        <td><span class="hwc-badge @roleClass">@role</span></td>
                        <td>@u.Gender</td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="hwc-no-match" data-empty style="display:none;">No users match your search.</div>
    </div>
}
