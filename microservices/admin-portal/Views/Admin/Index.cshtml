@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@model List<admin_portal.Models.DriverViewModel>

@{
    ViewData["Title"] = "Driver Verifications";
    var gateway = Configuration["ApiSettings:GatewayUrl"];
}

<div class="hwc-hero-band">
    <div>
        <h1>Driver Verifications</h1>
        <p>Review and approve drivers waiting to go online.</p>
    </div>
    <div class="hwc-hero-stat">
        <span class="hwc-hero-num">@(Model?.Count ?? 0)</span>
        <span class="hwc-hero-label">Pending</span>
    </div>
</div>

@if (TempData["Msg"] != null)
{
    <div class="hwc-flash hwc-flash-ok">@TempData["Msg"]</div>
}
@if (TempData["Err"] != null)
{
    <div class="hwc-flash hwc-flash-err">@TempData["Err"]</div>
}

@if (ViewBag.LoadError == true)
{
    <div class="hwc-flash hwc-flash-err">Couldn't load drivers — the driver service may be waking up. Refresh in a moment.</div>
}
else if (Model == null || !Model.Any())
{
    <div class="hwc-empty">
        <div class="hwc-empty-icon">&#10003;</div>
        <p>All caught up — no drivers pending verification.</p>
    </div>
}
else
{
    <div class="hwc-grid">
        @foreach (var driver in Model)
        {
            <div class="hwc-card">
                <div class="hwc-card-top">
                    <div class="hwc-avatar">@(string.IsNullOrEmpty(driver.Name) ? "D" : driver.Name.Substring(0, 1).ToUpper())</div>
                    <div>
                        <div class="hwc-card-name">@driver.Name</div>
                        <div class="hwc-card-id">Driver #@driver.Id</div>
                    </div>
                </div>

                <dl class="hwc-meta">
                    <div><dt>Email</dt><dd>@driver.Email</dd></div>
                    <div><dt>Phone</dt><dd>@driver.PhoneNumber</dd></div>
                    <div><dt>Gender</dt><dd>@driver.Gender</dd></div>
                </dl>

                <div class="hwc-card-actions">
                    @if (!string.IsNullOrEmpty(driver.DocumentPath))
                    {
                        <a href="@gateway/drivers/@driver.Id/document" target="_blank" rel="noopener" class="hwc-btn-outline">View Document</a>
                    }
                    else
                    {
                        <span class="hwc-nodoc">No document</span>
                    }
                    <form asp-action="Verify" method="post" class="hwc-verify-form">
                        <input type="hidden" name="id" value="@driver.Id" />
                        <button type="submit" class="hwc-btn">Approve Driver</button>
                    </form>
                </div>
            </div>
        }
    </div>
}
