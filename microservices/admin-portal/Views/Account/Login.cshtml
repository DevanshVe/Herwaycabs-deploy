@model admin_portal.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="hwc-login">
    <div class="hwc-login-card">
        <div class="hwc-login-head">
            <div class="hwc-logo hwc-logo-lg">H</div>
            <h1>HerWayCabs Admin</h1>
            <p>Sign in to manage driver verifications.</p>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="All" class="hwc-form-error"></div>

            <label class="hwc-label" asp-for="Email">Email</label>
            <input asp-for="Email" class="hwc-input" placeholder="admin@example.com" autofocus />

            <label class="hwc-label" asp-for="Password">Password</label>
            <input asp-for="Password" type="password" class="hwc-input" placeholder="Your password" />

            <button type="submit" class="hwc-btn hwc-btn-full">Sign In</button>
        </form>
    </div>
</div>
