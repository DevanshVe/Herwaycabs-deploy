@model admin_portal.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="hwc-login-hero">
    <div class="hwc-login-brand">
        <img src="~/logo.svg" class="hwc-login-brand-logo" alt="HerWayCabs" />
        <h2>HerWayCabs Admin</h2>
        <p>Safe rides, by women, for women.</p>
        <ul class="hwc-login-points">
            <li>Review &amp; approve driver documents</li>
            <li>Manage drivers, users &amp; rides</li>
            <li>Keep every journey safe</li>
        </ul>
    </div>

    <div class="hwc-login-panel">
        <div class="hwc-login-head">
            <h1>Welcome back</h1>
            <p>Sign in to the admin console.</p>
        </div>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="All" class="hwc-form-error"></div>

            <label class="hwc-label" asp-for="Email">Email</label>
            <input asp-for="Email" class="hwc-input" placeholder="admin@example.com" autofocus />

            <label class="hwc-label" asp-for="Password">Password</label>
            <input asp-for="Password" type="password" class="hwc-input" placeholder="Your password" />

            <button type="submit" class="hwc-btn hwc-btn-full">Sign In</button>
        </form>
    </div>
</div>
